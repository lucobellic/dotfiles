{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "snapshot": false,
  "share": "disabled",
  "autoshare": false,
  "autoupdate": true,
  "compaction": { "auto": false },
  "permission": {
    "*": "allow",
    "doom_loop": "ask",
  },
  "instructions": ["AGENTS.md", "~/.config/opencode/AGENTS.md"],
  "agent": {
    "explore": {
      "type": "subagent",
      "model": "github-copilot/gpt-5-mini",
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
  },
  "lsp": {
    "pyright": {
      "disabled": true,
    },
    "lua_ls": {
      "command": ["lua-language-server"],
      "extensions": [".lua"],
    },
    "clangd": {
      "command": [
        "clangd",
        "--all-scopes-completion",
        "--pch-storage=memory",
        "--clang-tidy",
        "--enable-config",
        "--header-insertion=iwyu",
        "--all-scopes-completion",
        "-j",
        "1",
      ],
      "extensions": [".c", ".cpp", ".ipp", ".h", ".hpp", ".cu", ".cuh"],
    },
    "ruff": {
      "command": ["ruff", "server", "--preview"],
      "extensions": [".py", ".pyi"],
    },
  },
}
